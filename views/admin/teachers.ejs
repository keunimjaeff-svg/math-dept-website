<%- include('layout', {pageTitle: 'Преподаватели'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Преподаватели</h1>
    <a href="/admin/teachers/new" class="btn-add">+ Добавить</a>
  </div>
  <% if (list.length === 0) { %>
    <p class="empty-admin">Преподавателей нет. <a href="/admin/teachers/new">Добавить первого</a></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Имя</th><th>Должность</th><th>Учёная степень</th><th>Email</th><th>Действия</th></tr></thead>
    <tbody>
      <% list.forEach(item => { %>
      <tr>
        <td><strong><%= item.name %></strong></td>
        <td><%= item.position_ru || '—' %></td>
        <td><%= item.degree_ru || '—' %></td>
        <td><%= item.email || '—' %></td>
        <td class="actions">
          <a href="/admin/teachers/<%= item.id %>/edit" class="btn-edit">✏️</a>
          <form method="POST" action="/admin/teachers/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить?')">
            <button type="submit" class="btn-del">🗑️</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
