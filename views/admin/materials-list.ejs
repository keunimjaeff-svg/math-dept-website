<%- include('layout', {pageTitle: 'Учебные материалы'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Учебные материалы</h1>
    <a href="/admin/materials/new" class="btn-add">+ Загрузить</a>
  </div>
  <% if (list.length === 0) { %>
    <p class="empty-admin">Материалов нет. <a href="/admin/materials/new">Загрузить первый</a></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Название</th><th>Автор</th><th>Тип</th><th>Файл</th><th>Действия</th></tr></thead>
    <tbody>
      <% list.forEach(item => { %>
      <tr>
        <td><%= item.title_ru %></td>
        <td><%= item.author || '—' %></td>
        <td><span class="badge badge-blue"><%= item.type==='book' ? '📚 Учебник' : '📝 Пособие' %></span></td>
        <td><a href="<%= item.file_path %>" target="_blank" class="file-link">📄 PDF</a></td>
        <td class="actions">
          <form method="POST" action="/admin/materials/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить?')">
            <button type="submit" class="btn-del">🗑️</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
