<%- include('layout', {pageTitle: 'Олимпиады'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Олимпиады</h1>
    <a href="/admin/olympiads/new" class="btn-add">+ Добавить</a>
  </div>
  <% if (list.length === 0) { %>
    <p class="empty-admin">Олимпиад нет. <a href="/admin/olympiads/new">Добавить первую</a></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Название (RU)</th><th>Дата события</th><th>Статус</th><th>Действия</th></tr></thead>
    <tbody>
      <% list.forEach(item => { %>
      <tr>
        <td><a href="/olympiads/<%= item.id %>" target="_blank"><%= item.title_ru %></a></td>
        <td><%= item.event_date || '—' %></td>
        <td><span class="badge <%= item.published ? 'badge-green' : 'badge-gray' %>"><%= item.published ? 'Опубликовано' : 'Скрыто' %></span></td>
        <td class="actions">
          <a href="/admin/olympiads/<%= item.id %>/edit" class="btn-edit">✏️</a>
          <form method="POST" action="/admin/olympiads/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить?')">
            <button type="submit" class="btn-del">🗑️</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
