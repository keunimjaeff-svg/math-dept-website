<%- include('layout', {pageTitle: 'Публикации'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Публикации (PDF)</h1>
    <a href="/admin/publications/new" class="btn-add">+ Загрузить</a>
  </div>
  <% if (list.length === 0) { %>
    <p class="empty-admin">Публикаций нет. <a href="/admin/publications/new">Загрузить первую</a></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Название</th><th>Автор</th><th>Год</th><th>Файл</th><th>Действия</th></tr></thead>
    <tbody>
      <% list.forEach(item => { %>
      <tr>
        <td><%= item.title_ru %></td>
        <td><%= item.author || '—' %></td>
        <td><%= item.year || '—' %></td>
        <td><a href="<%= item.file_path %>" target="_blank" class="file-link">📄 PDF</a></td>
        <td class="actions">
          <form method="POST" action="/admin/publications/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить?')">
            <button type="submit" class="btn-del">🗑️</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
