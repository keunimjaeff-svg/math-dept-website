<%- include('layout', {pageTitle: 'Загрузить материал'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Загрузить учебный материал</h1>
    <a href="/admin/materials" class="btn-back">← Назад</a>
  </div>
  <form method="POST" action="/admin/materials" enctype="multipart/form-data" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Название (RU) *</label>
        <input type="text" name="title_ru" required>
      </div>
      <div class="form-group">
        <label>Nomi (UZ)</label>
        <input type="text" name="title_uz">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Автор</label>
        <input type="text" name="author" placeholder="Ф.И.О. автора">
      </div>
      <div class="form-group">
        <label>Тип</label>
        <select name="type">
          <option value="book">📚 Darslik va o'quv qo'llanma / Учебник и учебное пособие</option>
          <option value="method">📝 O'quv-uslubiy material / Учебно-методический материал</option>
          <option value="lecture">🗒️ Ma'ruza matni / Конспект лекций</option>
          <option value="task">✏️ Masalalar to'plami / Сборник задач</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Дисциплина (RU)</label>
        <input type="text" name="subject_ru" placeholder="Прикладная математика">
      </div>
      <div class="form-group">
        <label>Fan (UZ)</label>
        <input type="text" name="subject_uz" placeholder="Amaliy matematika">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Описание (RU)</label>
        <textarea name="description_ru" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Tavsif (UZ)</label>
        <textarea name="description_uz" rows="3"></textarea>
      </div>
    </div>
    <div class="form-group">
      <label>PDF файл *</label>
      <input type="file" name="file" accept=".pdf" required>
      <span class="hint">Максимум 100 МБ</span>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-save">⬆ Загрузить</button>
      <a href="/admin/materials" class="btn-cancel">Отмена</a>
    </div>
  </form>
</div>
<%- include('layout-end') %>
