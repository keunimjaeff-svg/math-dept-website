<%- include('layout', {pageTitle: item ? 'Редактировать олимпиаду' : 'Новая олимпиада'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title"><%= item ? 'Редактировать' : 'Добавить олимпиаду' %></h1>
    <a href="/admin/olympiads" class="btn-back">← Назад</a>
  </div>
  <form method="POST" action="<%= action %>" enctype="multipart/form-data" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Название (RU) *</label>
        <input type="text" name="title_ru" value="<%= item ? item.title_ru : '' %>" required>
      </div>
      <div class="form-group">
        <label>Nomi (UZ)</label>
        <input type="text" name="title_uz" value="<%= item ? (item.title_uz||'') : '' %>">
      </div>
    </div>
    <div class="form-group">
      <label>Дата проведения</label>
      <input type="text" name="event_date" value="<%= item ? (item.event_date||'') : '' %>" placeholder="например: 15 апреля 2025">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Описание (RU)</label>
        <textarea name="content_ru" rows="8"><%= item ? (item.content_ru||'') : '' %></textarea>
      </div>
      <div class="form-group">
        <label>Tavsif (UZ)</label>
        <textarea name="content_uz" rows="8"><%= item ? (item.content_uz||'') : '' %></textarea>
      </div>
    </div>
    <div class="form-group">
      <label>Изображение <% if (item && item.image) { %><span class="hint">(<a href="<%= item.image %>" target="_blank">текущее</a>)</span><% } %></label>
      <input type="file" name="image" accept="image/*">
    </div>
    <div class="form-group form-check">
      <label><input type="checkbox" name="published" value="1" <%= (!item || item.published) ? 'checked' : '' %>> Опубликовать</label>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-save">💾 Сохранить</button>
      <a href="/admin/olympiads" class="btn-cancel">Отмена</a>
    </div>
  </form>
</div>
<%- include('layout-end') %>
