<%- include('layout', {pageTitle: 'Полезные источники'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Полезные источники</h1>
    <a href="/admin/links/new" class="btn-add">+ Добавить</a>
  </div>
  <% if (list.length === 0) { %>
    <p class="empty-admin">Источников нет. <a href="/admin/links/new">Добавить первый</a></p>
  <% } else { %>
  <table class="admin-table">
    <thead><tr><th>Название (RU)</th><th>Категория</th><th>URL</th><th>Порядок</th><th>Действия</th></tr></thead>
    <tbody>
      <% list.forEach(item => { %>
      <tr>
        <td><strong><%= item.title_ru %></strong><br><small style="color:#888"><%= item.title_uz||'' %></small></td>
        <td><%= item.category_ru || '—' %></td>
        <td><a href="<%= item.url %>" target="_blank" style="color:#2456a0;word-break:break-all"><%= item.url %></a></td>
        <td><%= item.order_num %></td>
        <td class="actions">
          <a href="/admin/links/<%= item.id %>/edit" class="btn-edit">✏️</a>
          <form method="POST" action="/admin/links/<%= item.id %>/delete" style="display:inline" onsubmit="return confirm('Удалить?')">
            <button type="submit" class="btn-del">🗑️</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<%- include('layout-end') %>
