<%- include('layout', {pageTitle: 'Загрузить публикацию'}) %>
<div class="admin-page">
  <div class="admin-page-header">
    <h1 class="admin-title">Загрузить публикацию</h1>
    <a href="/admin/publications" class="btn-back">← Назад</a>
  </div>
  <form method="POST" action="/admin/publications" enctype="multipart/form-data" class="admin-form">
    <div class="form-row">
      <div class="form-group">
        <label>Название (RU) *</label>
        <input type="text" name="title_ru" required>
      </div>
      <div class="form-group">
        <label>Nomi (UZ)</label>
        <input type="text" name="title_uz">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Автор</label>
        <input type="text" name="author" placeholder="Ф.И.О. автора">
      </div>
      <div class="form-group">
        <label>Год публикации</label>
        <input type="number" name="year" placeholder="2024" min="1990" max="2099">
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label>Описание (RU)</label>
        <textarea name="description_ru" rows="3"></textarea>
      </div>
      <div class="form-group">
        <label>Tavsif (UZ)</label>
        <textarea name="description_uz" rows="3"></textarea>
      </div>
    </div>
    <div class="form-group">
      <label>PDF файл *</label>
      <input type="file" name="file" accept=".pdf" required>
      <span class="hint">Максимум 100 МБ</span>
    </div>
    <div class="form-actions">
      <button type="submit" class="btn-save">⬆ Загрузить</button>
      <a href="/admin/publications" class="btn-cancel">Отмена</a>
    </div>
  </form>
</div>
<%- include('layout-end') %>
