<%- include('partials/head', {pageTitle: lang==='uz' ? "O'quv materiallari" : 'Учебные материалы'}) %>
<body>
<%- include('partials/header') %>
<main>
  <div class="page-hero">
    <div class="container"><h1><%= lang==='uz' ? "O'quv materiallari va darsliklar" : 'Учебные материалы и учебники' %></h1></div>
  </div>
  <section class="section">
    <div class="container">
      <% if (books.length > 0) { %>
      <h2 class="section-title">📚 <%= lang==='uz' ? 'Darsliklar va kitoblar' : 'Учебники и книги' %></h2>
      <div class="pdf-list">
        <% books.forEach(item => { %>
        <div class="pdf-item">
          <div class="pdf-icon">📚</div>
          <div class="pdf-info">
            <h3 class="pdf-title"><%= lang==='uz' ? (item.title_uz||item.title_ru) : item.title_ru %></h3>
            <% if (item.author) { %><p class="pdf-author">👤 <%= item.author %></p><% } %>
            <% if (item.subject_ru || item.subject_uz) { %>
            <p class="pdf-subject">📖 <%= lang==='uz' ? (item.subject_uz||item.subject_ru) : (item.subject_ru||item.subject_uz) %></p>
            <% } %>
            <% if (item.description_ru || item.description_uz) { %>
            <p class="pdf-desc"><%= lang==='uz' ? (item.description_uz||item.description_ru) : item.description_ru %></p>
            <% } %>
          </div>
          <a href="<%= item.file_path %>" class="btn btn-download" target="_blank" download>
            ⬇ <%= lang==='uz' ? 'Yuklab olish' : 'Скачать' %>
          </a>
        </div>
        <% }) %>
      </div>
      <% } %>

      <% if (other.length > 0) { %>
      <h2 class="section-title" style="margin-top:2.5rem">📝 <%= lang==='uz' ? 'Uslubiy qo\'llanmalar' : 'Методические пособия' %></h2>
      <div class="pdf-list">
        <% other.forEach(item => { %>
        <div class="pdf-item">
          <div class="pdf-icon">📝</div>
          <div class="pdf-info">
            <h3 class="pdf-title"><%= lang==='uz' ? (item.title_uz||item.title_ru) : item.title_ru %></h3>
            <% if (item.author) { %><p class="pdf-author">👤 <%= item.author %></p><% } %>
            <% if (item.subject_ru || item.subject_uz) { %>
            <p class="pdf-subject">📖 <%= lang==='uz' ? (item.subject_uz||item.subject_ru) : (item.subject_ru||item.subject_uz) %></p>
            <% } %>
          </div>
          <a href="<%= item.file_path %>" class="btn btn-download" target="_blank" download>
            ⬇ <%= lang==='uz' ? 'Yuklab olish' : 'Скачать' %>
          </a>
        </div>
        <% }) %>
      </div>
      <% } %>

      <% if (books.length === 0 && other.length === 0) { %>
        <p class="empty-msg"><%= lang==='uz' ? "Materiallar hali qo'shilmagan" : 'Материалы ещё не добавлены' %></p>
      <% } %>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
</body></html>
